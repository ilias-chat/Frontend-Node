# Local debugging for 401 token errors: show Firebase code + hint in JSON (never set AUTH_VERBOSE on production unless you accept extra detail in responses).
# NODE_ENV=development
# AUTH_VERBOSE=1

# CD: add the same JSON as GitHub Actions secret FIREBASE_SERVICE_ACCOUNT_JSON so Cloud Run receives it at deploy (see scripts/write-cloudrun-env.js).
# CD: add GitHub Actions secret API_FOOTBALL_KEY so Cloud Run can call API-Football (admin import).